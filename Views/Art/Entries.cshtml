@{
    ViewData["Title"] = "Add Entry";
}

@model Activity5_CRUD.Models.ArtViewModel

<div class="main">
    <div class="heading">
        <p>Your Entries</p>
        <button data-bs-toggle="modal" data-bs-target="#addEntryModal">Add Entry</button>
    </div>
    <div class="container">
        <div class="row row-cols-2 row-cols-lg-3 g-2 g-lg-3">
            @foreach (var art in Model.ArtList)
            {
                <div class="col">
                    <div class="card art-card">
                        <img src="@art.ImageUrl" class="card-img-top img-card" alt="Gallery">
                        <div class="card-body">
                            <h5 class="card-title">@art.ArtName</h5>
                            <p class="card-text">@art.Medium</p>
                            <hr />
                            <div class="d-flex gap-2">
                                <!-- Edit -->
                                <button type="button" class="btn btn-sm border-0 p-1"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editEntryModal"
                                        data-id="@art.Id"
                                        data-name="@art.ArtName"
                                        data-medium="@art.Medium"
                                        data-date="@art.Date.ToString("yyyy-MM-dd")"
                                        data-image="@art.ImageUrl">
                                    <img src="~/images/functions/edit_icon.svg" alt="Edit" class="icn-functions" />
                                </button>

                                <!-- Delete -->
                                <form method="post" asp-action="Delete" asp-route-id="@art.Id" style="display:inline">
                                    <button type="submit" class="btn btn-sm border-0 p-1"
                                            onclick="return confirm('Delete this entry?')">
                                        <img src="~/images/functions/delete_icon.svg" alt="Delete" class="icn-functions" />
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Add Entry Modal -->
    <div class="modal fade" id="addEntryModal" tabindex="-1" aria-labelledby="addEntryLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-body p-4">
                    <form method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="fw-bold">Title</label>
                            <input type="text" class="form-control text-input" asp-for="AddEntry.ArtName" />
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Select File</label>
                            <input type="file" class="form-control text-input" asp-for="AddEntry.ImageUrl" />
                        </div>
                        <div class="row mb-3">
                            <div class="col">
                                <label class="fw-bold">Medium</label>
                                <input type="text" class="form-control text-input" asp-for="AddEntry.Medium" />
                            </div>
                            <div class="col">
                                <label class="fw-bold">Date</label>
                                <input type="date" class="form-control" asp-for="AddEntry.Date" />
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn" style="background-color: #0d3b5e; color: white;">Save Entry</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Entry Modal -->
    <div class="modal fade" id="editEntryModal" tabindex="-1" aria-labelledby="editEntryLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-body p-4">
                    <form method="post" asp-action="Edit" enctype="multipart/form-data">

                        <input type="hidden" id="editId" asp-for="EditEntry.Id" />
                        <input type="hidden" id="editExistingImage" asp-for="EditEntry.ExistingImageUrl" />

                        <div class="mb-3">
                            <label class="fw-bold">Title</label>
                            <input type="text" class="form-control text-input" id="editArtName" asp-for="EditEntry.ArtName" />
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Select File</label>
                            <input type="file" class="form-control text-input" asp-for="EditEntry.ImageUrl" />
                            <small class="text-muted">Leave blank to keep existing image</small>
                        </div>
                        <div class="row mb-3">
                            <div class="col">
                                <label class="fw-bold">Medium</label>
                                <input type="text" class="form-control text-input" id="editMedium" asp-for="EditEntry.Medium" />
                            </div>
                            <div class="col">
                                <label class="fw-bold">Date</label>
                                <input type="date" class="form-control" id="editDate" asp-for="EditEntry.Date" />
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn" style="background-color: #0d3b5e; color: white;">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var editModal = document.getElementById('editEntryModal');
        editModal.addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            document.getElementById('editId').value = btn.getAttribute('data-id');
            document.getElementById('editArtName').value = btn.getAttribute('data-name');
            document.getElementById('editMedium').value = btn.getAttribute('data-medium');
            document.getElementById('editDate').value = btn.getAttribute('data-date');
            document.getElementById('editExistingImage').value = btn.getAttribute('data-image');
        });
    </script>
}